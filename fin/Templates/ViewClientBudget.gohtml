{{ define "Home" }}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DetailDossier</title>
</head>
<body>
    <h1>ViewClientBudget</h1>

    <p>ID: {{ .ID }}</p>
    <p>MaxBedrag: {{ .MaxBedrag }}</p>
    <p>BeschikbaarBedrag: {{ .BeschikbaarBedrag }}</p>
    <p>GebruiktBedrag: {{ .GebruiktBedrag }}</p>
    <p>BudgetStatus: {{ .BudgetStatus }}</p>
</body>

{{ end }}